---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TOC from '../../../components/TOC.astro';
import { createPageTitle, themeConfig } from '../../lib/theme.js';

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts
    .filter((post) => post.data.draft !== true)
    .map((post) => ({
      params: { id: post.id },
      props: { post },
    }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const copyLabel = themeConfig.labels.copyCode;
const copiedLabel = themeConfig.labels.copiedCode;
---

<BaseLayout
  title={createPageTitle(post.data.title)}
  description={post.data.description ?? post.data.title}
  image={post.data.image ?? themeConfig.ogImage}
  article={true}
>
  <article class="post">
    <header class="post-header">
      <h1>{post.data.title}</h1>
      <div class="post-meta">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toISOString().slice(0, 10)}
        </time>
        {post.data.tags.length > 0 && (
          <span class="tags">
            ·
            {post.data.tags.map((tag) => (
              <a href={`/tags/${encodeURIComponent(tag)}/`} class="tag">#{tag}</a>
            ))}
          </span>
        )}
      </div>
    </header>

    <TOC headings={headings} />

    <div class="post-content">
      <Content />
    </div>
  </article>
</BaseLayout>

<style is:global>
  .post-header {
    margin-bottom: 2rem;
  }

  .post-meta {
    color: var(--color-border);
    font-size: 0.9rem;
  }

  .tag {
    margin-left: 0.5rem;
  }

  .copy-code-wrapper {
    position: relative;
  }

  .copy-code-button {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.2rem 0.5rem;
    background-color: var(--color-bg);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    font-size: 0.8rem;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .copy-code-wrapper:hover .copy-code-button {
    opacity: 1;
  }

  .post-content pre {
    padding: 1rem;
    border-radius: 4px;
    overflow-x: auto;
    border: 1px solid var(--color-border);
  }
</style>

<script is:inline define:vars={{ copyLabel, copiedLabel }}>
  function setupCodeCopy() {
    const blocks = document.querySelectorAll('pre');

    blocks.forEach((block) => {
      const parent = block.parentNode;
      if (parent instanceof HTMLElement && parent.classList.contains('copy-code-wrapper')) {
        return;
      }

      if (!(parent instanceof HTMLElement)) return;

      const wrapper = document.createElement('div');
      wrapper.className = 'copy-code-wrapper';
      parent.insertBefore(wrapper, block);
      wrapper.appendChild(block);

      const button = document.createElement('button');
      button.className = 'copy-code-button';
      button.innerText = copyLabel;

      button.addEventListener('click', async () => {
        const code = block.querySelector('code');
        if (!code) return;

        try {
          await navigator.clipboard.writeText(code.innerText);
          button.innerText = copiedLabel;
          setTimeout(() => {
            button.innerText = copyLabel;
          }, 2000);
        } catch (error) {
          console.error('Failed to copy', error);
        }
      });

      wrapper.appendChild(button);
    });
  }

  document.addEventListener('astro:page-load', setupCodeCopy);
</script>
