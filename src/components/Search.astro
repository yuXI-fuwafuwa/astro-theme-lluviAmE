---
---
<div id="search" class="search-container"></div>

<script>
  type PagefindUIConstructor = new (options: {
    element: string;
    showSubResults: boolean;
  }) => unknown;

  function mountSearch() {
    const pagefindWindow = window as Window & typeof globalThis & {
      PagefindUI?: PagefindUIConstructor;
    };

    if (!pagefindWindow.PagefindUI) return;

    const searchDiv = document.getElementById('search');
    if (!searchDiv || searchDiv.innerHTML !== '') return;

    new pagefindWindow.PagefindUI({
      element: '#search',
      showSubResults: true,
    });
  }

  function initPagefind() {
    const pagefindWindow = window as Window & typeof globalThis & {
      PagefindUI?: PagefindUIConstructor;
    };

    if (pagefindWindow.PagefindUI) {
      mountSearch();
      return;
    }

    if (!document.querySelector('link[data-pagefind-ui]')) {
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = '/pagefind/pagefind-ui.css';
      link.dataset.pagefindUi = 'true';
      document.head.appendChild(link);
    }

    const existingScript = document.querySelector('script[data-pagefind-ui]');
    if (!(existingScript instanceof HTMLScriptElement)) {
      const script = document.createElement('script');
      script.src = '/pagefind/pagefind-ui.js';
      script.dataset.pagefindUi = 'true';
      script.addEventListener('load', mountSearch, { once: true });
      document.head.appendChild(script);
      return;
    }

    existingScript.addEventListener('load', mountSearch, { once: true });
  }

  document.addEventListener('astro:page-load', initPagefind);
</script>

<style is:global>
  .search-container {
    margin-bottom: 2rem;
  }
  
  /* Make pagefind adapt to our theme */
  html[data-theme='dark'] {
    --pagefind-ui-primary: #66b2ff;
    --pagefind-ui-text: #e0e0e0;
    --pagefind-ui-background: #121212;
    --pagefind-ui-border: #333333;
    --pagefind-ui-tag: #333333;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 4px;
    --pagefind-ui-image-border-radius: 4px;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: var(--font-base);
  }
  
  html[data-theme='light'] {
    --pagefind-ui-primary: #0000ee;
    --pagefind-ui-text: #000000;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #cccccc;
    --pagefind-ui-tag: #eeeeee;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 4px;
    --pagefind-ui-image-border-radius: 4px;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: var(--font-base);
  }
</style>
