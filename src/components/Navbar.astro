---
---
<header class="navbar">
  <div class="navbar-inner">
    <nav class="nav-links">
      <a href="/">Home</a>
      <span class="separator">|</span>
      <a href="/blog">Blog</a>
      <span class="separator">|</span>
      <a href="/tags">Tags</a>
    </nav>
    <div class="nav-right">
      <button id="theme-toggle" aria-label="Toggle Dark Mode" title="Toggle Dark Mode">
        <span class="theme-icon light-icon">☼</span>
        <span class="theme-icon dark-icon">☾</span>
      </button>
      <span class="separator">|</span>
      <a href="#" class="back-to-top" aria-label="Back to Top">Top ↑</a>
    </div>
  </div>
</header>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    padding: 10px 0;
  }
  .navbar-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: var(--max-width-wide);
    margin: 0 auto;
    box-sizing: border-box;
  }
  
  @media (max-width: 768px) {
    .navbar-inner {
      width: var(--max-width-narrow);
      padding: 0 1rem;
    }
  }

  .nav-links, .nav-right {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  
  .separator {
    color: var(--color-border);
  }
  
  #theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    color: var(--color-text);
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  html[data-theme='dark'] .light-icon {
    display: none;
  }
  html[data-theme='light'] .dark-icon,
  html:not([data-theme='dark']) .dark-icon {
    display: none;
  }
</style>